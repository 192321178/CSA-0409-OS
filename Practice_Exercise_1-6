#include <stdio.h>

#define SIZE 3

int main() {

    int pages[] = {1,2,3,4,1,2,5};
    int frame[SIZE];
    int index = 0;

    for(int i=0;i<SIZE;i++)
        frame[i]=-1;

    for(int i=0;i<7;i++){

        int found=0;

        for(int j=0;j<SIZE;j++){
            if(frame[j]==pages[i]){
                found=1;
                break;
            }
        }

        if(!found){
            frame[index]=pages[i];
            index=(index+1)%SIZE;
        }

        printf("Frames: ");

        for(int j=0;j<SIZE;j++)
            printf("%d ",frame[j]);

        printf("\n");
    }

    return 0;
}
