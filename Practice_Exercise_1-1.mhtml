ontent, .ace_hidpi .ace_gutter { contain: strict; }

.ace_hidpi .ace_text-layer > .ace_line, .ace_hidpi .ace_text-layer > .ace_l=
ine_group { contain: strict; }

.ace_cjk { display: inline-block; text-align: center; }

