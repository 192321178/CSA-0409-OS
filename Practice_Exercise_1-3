#include <stdio.h>

#define SIZE 5

int queue[SIZE];
int front = -1, rear = -1;

void enqueue(int p) {
    if (rear == SIZE - 1) {
        printf("Queue Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = p;
}

void display() {
    printf("Ready Queue: ");

    for (int i = front; i <= rear; i++)
        printf("P%d ", queue[i]);

    printf("\n");
}

int main() {

    enqueue(1);
    enqueue(2);
    enqueue(3);
    enqueue(4);

    display();

    return 0;
}
